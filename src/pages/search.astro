---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Server-side search logic
const query = Astro.url.searchParams.get('q')?.toLowerCase() || '';

// Fetch all project pages
const allProjects = await Astro.glob('./project/*.astro');

const searchResults = allProjects.filter(project => {
  if (!query) return false;
  
  const titleMatch = project.frontmatter.title.toLowerCase().includes(query);
  const descriptionMatch = project.frontmatter.description.toLowerCase().includes(query);
  // You could also add a check against post.rawContent() for full-text search
  // const contentMatch = project.rawContent().toLowerCase().includes(query);

  return titleMatch || descriptionMatch;
});
---

<Layout title={`نتائج البحث عن: ${query}`}>
  <div class="search-results-page">
    <div class="container">
      <header class="search-header">
        <h1>نتائج البحث</h1>
        {query && <p>أنت تبحث عن: <span class="query-term">{query}</span></p>}
      </header>

      {query ? (
        <div class="results-container">
          {searchResults.length > 0 ? (
            <div class="projects-grid">
              {searchResults.map(project => (
                <ProjectCard 
                  project={{
                    slug: project.url,
                    name: project.frontmatter.title,
                    image: project.frontmatter.image,
                    description: project.frontmatter.description,
                    status: project.frontmatter.status
                  }} 
                />
              ))}
            </div>
          ) : (
            <div id="no-results" class="no-results-message">
              <h2>لم يتم العثور على نتائج</h2>
              <p>عذرًا، لم نتمكن من العثور على أي نتائج لكلمة البحث هذه. جرب البحث بكلمات أخرى.</p>
            </div>
          )}
        </div>
      ) : (
        <div class="no-query-message">
            <h2>ابحث في مشاريعنا</h2>
            <p>استخدم شريط البحث في الأعلى للعثور على المشاريع حسب الاسم أو الوصف.</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .search-results-page {
    padding: 8rem 0 4rem;
    color: #fff;
    min-height: calc(100vh - 120px); /* Adjust based on header/footer height */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .search-header {
    text-align: center;
    margin-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    padding-bottom: 2rem;
  }

  .search-header h1 {
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
  }

  .search-header p {
    font-size: 1.2rem;
    color: #ccc;
  }

  .query-term {
    color: #ffd700;
    font-weight: bold;
  }

  .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
      padding: 2rem 0;
  }

  .no-results-message, .no-query-message {
    text-align: center;
    padding: 4rem 2rem;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 15px;
    margin-top: 2rem;
  }

  .no-results-message h2, .no-query-message h2 {
    font-size: 2rem;
    color: #ffd700;
    margin-bottom: 1rem;
  }

  .no-results-message p, .no-query-message p {
    font-size: 1.1rem;
    color: #ccc;
  }

  @media (max-width: 768px) {
    .search-header h1 {
      font-size: 2.2rem;
    }
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
