---
import Layout from '../layouts/Layout.astro';
import { pageContent } from '../data/pages.js';

const { contact } = pageContent;
---

<Layout title={`اتصل بنا - ${contact.name}`}>
  <div class="contact-page">
    <div class="page-header">
      <div class="container">
        <h1 class="page-title">{contact.title}</h1>
        <p class="page-subtitle">{contact.subtitle}</p>
      </div>
    </div>

    <div class="page-content">
      <div class="container">
        <div class="content-wrapper">
          <div class="contact-info">
            <h2 class="section-title">{contact.info.title}</h2>
            <p>{contact.info.description}</p>
            <ul>
              <li><strong><i class="icon">📍</i> العنوان:</strong> {contact.info.address}</li>
              <li><strong><i class="icon">📧</i> البريد الإلكتروني:</strong> <a href={`mailto:${contact.info.email}`}>{contact.info.email}</a></li>
              <li><strong><i class="icon">📞</i> الهاتف:</strong> <a href={`tel:${contact.info.phone}`}>{contact.info.phone}</a></li>
            </ul>
          </div>

          <div class="contact-form">
            <h2 class="section-title">{contact.form.title}</h2>
            <form>
              <div class="form-group">
                <label for="name">الاسم</label>
                <input type="text" id="name" placeholder="اسمك الكامل" required>
              </div>
              <div class="form-group">
                <label for="email">البريد الإلكتروني</label>
                <input type="email" id="email" placeholder="بريدك الإلكتروني" required>
              </div>
              <div class="form-group">
                <label for="message">رسالتك</label>
                <textarea id="message" rows="6" placeholder="كيف يمكننا مساعدتك؟" required></textarea>
              </div>
              <button type="submit" class="submit-btn">إرسال الرسالة</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .contact-page {
    background-color: var(--background);
    padding-bottom: 4rem;
  }

  .page-header {
    background-color: transparent; /* Removed blue gradient */
    text-align: right;
    padding: 160px 0 80px 0;
  }

  .page-title {
    font-size: 3.5rem;
    color: var(--primary); /* Changed from #fff */
    margin-bottom: 1rem;
  }

  .page-subtitle {
    font-size: 1.2rem;
    max-width: 800px;
    color: var(--text-dark); /* Changed from #fff */
    opacity: 0.95;
  }

  .page-content {
    padding: 4rem 0;
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    background-color: #ffffff;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .section-title {
    font-size: 2.2rem;
    color: var(--primary);
    margin-bottom: 1.5rem;
  }

  .contact-info p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .contact-info ul {
    list-style: none;
    padding: 0;
  }

  .contact-info li {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--text-dark);
    display: flex;
    align-items: center;
  }

  .contact-info .icon {
    color: var(--accent);
    margin-left: 10px; 
    font-style: normal;
  }

  .contact-info a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-info a:hover {
    color: var(--primary);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 700;
    color: var(--primary);
  }

  .form-group input, 
  .form-group textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid #ccc;
    border-radius: 8px;
    font-size: 1rem;
    font-family: 'Cairo', sans-serif;
  }

  .submit-btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(90deg, var(--accent), var(--secondary));
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(var(--accent-rgb), 0.3);
  }

  @media (max-width: 992px) {
    .content-wrapper {
        grid-template-columns: 1fr;
        gap: 3rem;
        padding: 2rem;
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 120px 0 60px 0;
    }
    .page-title {
      font-size: 2.8rem;
    }
  }
</style>