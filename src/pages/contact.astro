---
import Layout from '../layouts/Layout.astro';
import NewContactForm from '../components/NewContactForm.astro';
---

<Layout title="اتصل بنا - شركة الايمان للتطوير العقاري">
  <main class="contact-page">
    <div class="container">
      <h1 class="page-title">تواصل معنا</h1>
      <p class="page-subtitle">
        نحن هنا للإجابة على جميع استفساراتك. سواء كنت مهتمًا بمشاريعنا، أو لديك فرصة استثمارية، أو ترغب فقط في معرفة المزيد، فلا تتردد في التواصل معنا.
      </p>
      
      <div class="contact-details-grid">
        <!-- Contact Card: Address -->
        <div class="contact-card">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <h3>عنوان المكتب</h3>
          <p>مصر، سوهاج، طما، أعلى بنك القاهرة</p>
        </div>

        <!-- Contact Card: Email -->
        <div class="contact-card">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </div>
          <h3>البريد الإلكتروني</h3>
          <p><a href="mailto:info@eleman.com">info@eleman.com</a></p>
        </div>

        <!-- Contact Card: Phone -->
        <div class="contact-card">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <h3>الهاتف</h3>
          <p><a href="tel:+201002672901">+20 100 267 2901</a></p>
        </div>
      </div>

      <!-- Contact Form -->
      <NewContactForm />
    </div>
  </main>
</Layout>

<style>
  .contact-page {
    padding-top: 8rem !important; 
    padding-bottom: 4rem;
    padding-left: 2rem;
    padding-right: 2rem;
    color: #fff;
    min-height: 100vh;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }

  .page-title {
    font-size: 3.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
    text-shadow: 0px 4px 10px rgba(0, 0, 0, 0.5);
    margin-top: -3rem; /* Directly lifting the title a bit more */
  }

  .page-subtitle {
    font-size: 1.25rem;
    max-width: 700px;
    margin: 0 auto 4rem auto;
    color: #ccc;
    line-height: 1.8;
  }

  .contact-details-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .contact-card {
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    padding: 2.5rem 2rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .contact-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
  }

  .card-icon {
    margin-bottom: 1.5rem;
    color: #ffd700; /* Gold color for the icon */
  }

  .contact-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }

  .contact-card p, .contact-card a {
    font-size: 1rem;
    color: #ccc;
    text-decoration: none;
    line-height: 1.6;
  }

  .contact-card a:hover {
    color: #ffd700;
    text-decoration: underline;
  }

  @media (max-width: 992px) {
    .contact-details-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
