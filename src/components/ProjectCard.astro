---
interface Props {
  project: {
    slug: string;
    name: string;
    image: string;
    description: string;
    status: 'delivered' | 'under-construction';
  };
}

const { project } = Astro.props;
const statusText = project.status === 'delivered' ? 'تم التسليم' : 'تحت الإنشاء';
const statusClass = project.status === 'delivered' ? 'status-delivered' : 'status-under-construction';
---

<a href={project.slug} class="project-card">
  <div class="card-image">
    <img src={project.image} alt={`صورة مشروع ${project.name}`} loading="lazy" width="400" height="300">
    <div class={`status-badge ${statusClass}`}>{statusText}</div>
  </div>
  <div class="card-content">
    <h3 class="card-title">{project.name}</h3>
    <p class="card-description">{project.description}</p>
    <span class="card-link">عرض التفاصيل &rarr;</span>
  </div>
</a>

<style>
  .project-card {
    display: block;
    background-color: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    border-radius: 15px;
    overflow: hidden;
    text-decoration: none;
    color: rgb(var(--text-dark));
    border: 1px solid rgba(255, 255, 255, 0.9);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  .project-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.15);
  }

  .card-image {
    position: relative;
    width: 100%;
    height: 200px;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .card-image img {
      transform: scale(1.05);
  }

  .status-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 1;
    backdrop-filter: blur(5px);
  }

  .status-delivered {
    background-color: rgba(46, 204, 113, 0.7);
  }

  .status-under-construction {
    background-color: rgba(243, 156, 18, 0.7);
  }

  .card-content {
    padding: 1.5rem;
  }

  .card-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    color: rgb(var(--primary));
  }

  .card-description {
    font-size: 0.95rem;
    color: inherit;
    opacity: 0.8;
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .card-link {
    display: inline-block;
    font-weight: bold;
    color: rgb(var(--primary));
    opacity: 0.9;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .project-card:hover .card-link {
    transform: translateX(5px);
    opacity: 1;
  }
</style>
