---
// src/components/ProjectsSection.astro
---

<section class="projects-section">
  <h2 class="section-title">مشاريع تم تنفيذها</h2>
  <div class="projects-grid">
    <!-- Project Card 1: Gaza Tower -->
    <div class="project-card">
      <div class="card-content">
        <img src="https://i.postimg.cc/yY1Hvq56/brj-ghzh.jpg" alt="برج غزة" class="project-image" />
        <div class="project-info">
          <h3>برج غزة</h3>
          <a href="#" class="details-button">عرض التفاصيل</a>
        </div>
      </div>
    </div>

    <!-- Project Card 2: Makkah Tower -->
    <div class="project-card">
      <div class="card-content">
        <img src="https://i.postimg.cc/qMJTjfYp/brj-mkh.jpg" alt="برج مكة" class="project-image" />
        <div class="project-info">
          <h3>برج مكة</h3>
          <a href="#" class="details-button">عرض التفاصيل</a>
        </div>
      </div>
    </div>

    <!-- Project Card 3: Al-Aqsa Tower -->
    <div class="project-card">
      <div class="card-content">
        <img src="https://i.postimg.cc/NfscphVg/brj-alaqsy.jpg" alt="برج الأقصى" class="project-image" />
        <div class="project-info">
          <h3>برج الأقصى</h3>
          <a href="#" class="details-button">عرض التفاصيل</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 5rem 2rem;
    text-align: center;
  }

  .section-title {
    font-size: 2.8rem;
    color: #fff;
    font-weight: 900;
    position: relative;
    padding-bottom: 1.5rem;
    margin-bottom: 4rem; /* Increased margin to compensate for removed subtitle */
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background-color: #fff;
    border-radius: 2px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .project-card {
    transition: transform 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-8px);
  }

  .card-content {
    height: 100%;
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    overflow: hidden; /* Ensures image corners are rounded */
    transition: background-color 0.3s ease;
  }

  .project-card:hover .card-content {
    background-color: rgba(255, 255, 255, 0.2);
  }

  .project-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 1.5rem;
  }

  .project-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .project-info h3 {
    font-size: 1.5rem;
    color: #fff;
    margin: 0;
  }

  .details-button {
    background-color: transparent;
    border: 1px solid #fff;
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    text-decoration: none;
    font-size: 0.9rem;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .details-button:hover {
    background-color: #fff;
    color: #1a1a1a;
  }
</style>
