---
import NavLink from './NavLink.astro';
import Search from './Search.astro';
--- 
<header class="site-header">
    <div class="company-name">
        <h2><a href="/" class="pulsating-glow">شركة الايمان للاستثمار والتطوير العقاري</a></h2>
    </div>
    <div class="header-bottom-bar">
        <nav class="main-nav">
            <NavLink href="/" text="الرئيسية" />
            <NavLink href="/about" text="من نحن" />
            <NavLink href="/projects" text="مشاريعنا" />
            <NavLink href="/contact" text="اتصل بنا" />
        </nav>
        <div class="header-actions">
            <Search />
            <a href="https://wa.me/+201002672901" class="whatsapp-icon" target="_blank" aria-label="تواصل معنا عبر واتساب">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
            </a>
        </div>
    </div>
</header>

<style>
    .site-header {
        background-color: rgba(255, 255, 255, 0.1);
        padding: 1rem 2rem;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        box-sizing: border-box;
    }

    .company-name {
        margin-bottom: 1rem;
        text-align: center;
    }

    .company-name h2 {
        font-size: 1.8rem;
        font-weight: 900;
        margin: 0;
    }

    /* NEW: Pulsating Glow Effect */
    .company-name a.pulsating-glow {
        color: #fff;
        text-decoration: none;
        animation: pulsating-glow-animation 3s infinite ease-in-out;
        transition: transform 0.3s ease, text-shadow 0.3s ease;
    }

    .company-name a.pulsating-glow:hover {
        animation-play-state: paused;
        text-shadow:
            0 0 5px #fff,
            0 0 15px #fff,
            0 0 25px #ffd700,
            0 0 40px #ffd700;
        transform: scale(1.03);
    }

    @keyframes pulsating-glow-animation {
        0% {
            text-shadow: 0 0 5px rgba(255, 215, 0, 0.5);
        }
        50% {
            text-shadow:
                0 0 8px #fff,
                0 0 18px #ffd700,
                0 0 28px #ffd700;
        }
        100% {
            text-shadow: 0 0 5px rgba(255, 215, 0, 0.5);
        }
    }

    .header-bottom-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        gap: 2rem;
    }

    .main-nav {
        display: flex;
        gap: 2rem;
    }
    
    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .whatsapp-icon svg {
        stroke: #fff;
        transition: stroke 0.3s ease, transform 0.3s ease;
        filter: drop-shadow(0px 2px 3px rgba(0,0,0,0.4));
    }

    .whatsapp-icon:hover svg {
        stroke: #25D366;
        transform: scale(1.1);
    }
</style>
