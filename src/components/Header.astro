---
import NavLink from './NavLink.astro';
import Search from './Search.astro';
const companyName = "شركة الايمان للاستثمار والتطوير العقاري";
const words = companyName.split(' ');
--- 
<header class="site-header">
    <div class="top-bar">
        <div class="company-name">
            <h2>
                <a href="/">
                    {words.map((word, index) => (
                        <span style={`transition-delay: ${index * 0.05}s`}>{word}&nbsp;</span>
                    ))}
                </a>
            </h2>
        </div>
        <button class="hamburger-menu" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
    </div>
    <div class="header-bottom-bar">
        <nav class="main-nav">
            <NavLink href="/" text="الرئيسية" />
            <NavLink href="/about" text="من نحن" />
            <NavLink href="/projects" text="مشاريعنا" />
            <NavLink href="/contact" text="اتصل بنا" />
        </nav>
        <div class="header-actions">
            <Search />
            <a href="https://wa.me/+201002672901" class="whatsapp-icon" target="_blank" aria-label="تواصل معنا عبر واتساب">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
            </a>
        </div>
    </div>
</header>

<script>
    const hamburger = document.querySelector('.hamburger-menu');
    const navMenu = document.querySelector('.header-bottom-bar');

    hamburger.addEventListener('click', () => {
        navMenu.classList.toggle('is-active');
    });
</script>

<style>
    .site-header {
        background-color: rgba(255, 255, 255, 0.1);
        padding: 1rem 2rem;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        box-sizing: border-box;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        margin-bottom: 1rem; /* Space between name and nav */
    }

    .company-name h2 {
        font-size: 1.8rem;
        font-weight: 900;
        margin: 0;
    }
    
    .company-name a {
        color: #fff;
        text-decoration: none;
        display: inline-block;
    }

    .company-name a span {
        display: inline-block;
        transition: transform 0.3s ease, color 0.3s ease;
    }

    .company-name a:hover span {
        transform: translateY(-5px);
        color: #8A2BE2;
    }

    .header-bottom-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        gap: 2rem;
    }

    .main-nav {
        display: flex;
        gap: 2rem;
    }
    
    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .whatsapp-icon svg {
        stroke: #fff;
        transition: stroke 0.3s ease, transform 0.3s ease;
        filter: drop-shadow(0px 2px 3px rgba(0,0,0,0.4));
    }

    .whatsapp-icon:hover svg {
        stroke: #25D366;
        transform: scale(1.1);
    }
    
    .hamburger-menu {
        display: none; /* Hidden by default */
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 11; /* Ensure it's above other elements */
    }

    @media (max-width: 768px) {
        .site-header {
            padding: 1rem;
            position: static;
            flex-direction: column;
            align-items: flex-start;
        }

        .top-bar {
            margin-bottom: 0;
        }

        .hamburger-menu {
            display: block; /* Show hamburger on mobile */
        }

        .header-bottom-bar {
            display: none; /* Hide nav by default on mobile */
            flex-direction: column;
            align-items: center;
            width: 100%;
            background-color: rgba(15, 23, 42, 0.95); /* Dark background for sidebar */
            position: absolute;
            top: 70px; /* Position below header */
            left: 0;
            right: 0;
            padding: 2rem 0;
            gap: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(5px);
        }
        
        .header-bottom-bar.is-active {
            display: flex; /* Show when active */
        }

        .main-nav {
            flex-direction: column;
            gap: 1.5rem;
            text-align: center;
            width: 100%;
        }

        .company-name h2 {
            font-size: 1.4rem;
        }
    }
</style>