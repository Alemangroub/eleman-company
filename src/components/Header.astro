---
import NavLink from './NavLink.astro';
import Search from './Search.astro';
--- 
<header id="main-header" class="site-header">
    <div class="container">
        <div class="header-content">
            <a href="/" class="logo-container" aria-label="Eleman Company Home">
                <svg width="0" height="0" style="position:absolute">
                    <defs>
                        <linearGradient id="logo-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" style="stop-color:#80e6ff;" />
                            <stop offset="100%" style="stop-color:#d8648c;" />
                        </linearGradient>
                    </defs>
                </svg>
                <div class="logo-shape">
                    <svg class="house-outline" viewBox="0 20 100 80" preserveAspectRatio="xMidYMid meet">
                        <path d="M 25 90 L 32 80 L 32 42 L 50 25 L 68 42 L 68 90" stroke="url(#logo-gradient)" stroke-width="5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="logo-text">
                    <span class="eleman">Eleman</span>
                    <span class="company">Company</span>
                    <span class="tagline">For real estate investment</span>
                </div>
            </a>
            
            <div class="nav-and-actions">
                <nav class="main-nav">
                    <NavLink href="/" text="الرئيسية" />
                    <NavLink href="/about" text="من نحن" />
                    <NavLink href="/projects" text="مشاريعنا" />
                    <NavLink href="/contact" text="اتصل بنا" />
                </nav>
                <div class="header-actions">
                    <Search />
                    <a href="https://wa.me/+201002672901" class="whatsapp-icon" target="_blank" aria-label="تواصل معنا عبر واتساب">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    </a>
                </div>
            </div>

            <button class="hamburger-menu" aria-label="Toggle menu" aria-expanded="false">
                <svg class="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                <svg class="close-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
    </div>
</header>

<script>
    const hamburger = document.querySelector('.hamburger-menu');
    const navAndActions = document.querySelector('.nav-and-actions');
    const header = document.getElementById('main-header');

    hamburger.addEventListener('click', () => {
        const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!isExpanded));
        navAndActions.classList.toggle('is-active');
        header.classList.toggle('is-active');
        document.body.classList.toggle('no-scroll');
    });
</script>

<style>
   .site-header {
    background: transparent;
    padding: 1rem 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    }

    .container {
        width: 90%;
        max-width: 1300px;
        margin: 0 auto;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo-container {
        display: grid;
        place-items: center;
        width: 250px;
        text-decoration: none;
    }

    .logo-shape, .logo-text {
        grid-area: 1 / 1;
    }

    .logo-shape {
        width: 100%;
        height: 75px;
    }

    .house-outline {
        width: 100%;
        height: 100%;
    }

    .logo-text {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white; /* Fallback */
    }

    .logo-text span {
        font-family: 'Orbitron', sans-serif;
        background: linear-gradient(90deg, #80e6ff, #d8648c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-fill-color: transparent;
        font-weight: 600;
        line-height: 1.1;
        opacity: 0;
        animation: fadeInDown 0.5s forwards;
    }

    .logo-text .eleman { font-size: 2rem; animation-delay: 0.1s; }
    .logo-text .company { font-size: 1.6rem; margin-top: -2px; animation-delay: 0.2s;}
    .logo-text .tagline {
        font-family: 'Cairo', sans-serif;
        font-size: 0.6rem;
        font-weight: 400;
        margin-top: 2px;
        animation-delay: 0.3s;
    }

    .main-nav :global(a),
    .header-actions > *,
    .hamburger-menu {
        opacity: 0;
        animation: fadeInDown 0.5s forwards;
        text-shadow: none;
    }

    .main-nav :global(a):nth-child(1) { animation-delay: 0.6s; }
    .main-nav :global(a):nth-child(2) { animation-delay: 0.7s; }
    .main-nav :global(a):nth-child(3) { animation-delay: 0.8s; }
    .main-nav :global(a):nth-child(4) { animation-delay: 0.9s; }
    
    .header-actions > :first-child { animation-delay: 1s; }
    .header-actions > :last-child { animation-delay: 1.1s; }

    .hamburger-menu {
        animation-delay: 1.2s;
    }
    
    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .nav-and-actions {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .main-nav {
        display: flex;
        gap: 2.5rem;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .whatsapp-icon svg {
        stroke: black;
        transition: transform 0.3s;
    }

    .whatsapp-icon:hover svg {
        transform: scale(1.1);
    }
    
    .hamburger-menu {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 1001;
        color: black;
    }

    .close-icon {
        display: none;
    }

    .hamburger-menu[aria-expanded="true"] .hamburger-icon {
        display: none;
    }
    .hamburger-menu[aria-expanded="true"] .close-icon {
        display: block;
    }
     .hamburger-menu[aria-expanded="true"] {
        color: rgb(var(--text-light));
     }

    @media (max-width: 1024px) {
        .logo-container {
            width: 180px;
        }
        .logo-text .eleman { font-size: 1.5rem; }
        .logo-text .company { font-size: 1.2rem; }
        .logo-text .tagline { font-size: 0.5rem; }
        .main-nav {
            gap: 1.5rem;
        }
    }

    @media (max-width: 768px) {
        .header-content {
            justify-content: flex-end; 
        }
        .logo-container {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            top: 15px; 
        }
        .hamburger-menu {
            display: block;
        }

        .nav-and-actions {
            display: none;
            flex-direction: column;
            align-items: center;
            /* Changed from justify-content: center */
            justify-content: flex-start;
            padding-top: 25vh; /* Added padding to push content down */
            gap: 3rem; /* Increased gap for better spacing */
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(var(--primary-rgb), 0.95);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            transform: translateX(100%);
            transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            overflow-y: auto; /* Add scroll for smaller screens */
        }
        
        .nav-and-actions.is-active {
            display: flex;
            transform: translateX(0);
        }

        .main-nav {
            flex-direction: column;
            gap: 2rem;
            text-align: center;
        }
        
        .header-actions {
            flex-direction: column;
            gap: 2rem;
        }

        .header-actions .whatsapp-icon svg {
            stroke: rgb(var(--text-light));
            width: 32px;
            height: 32px;
        }
        
        .nav-and-actions.is-active :global(.search-input) {
            background-color: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
            color: rgb(var(--text-light));
            width: 80%;
            max-width: 300px;
        }

        .nav-and-actions.is-active :global(.search-input::placeholder) {
            color: rgba(255, 255, 255, 0.6);
        }

        .nav-and-actions.is-active :global(.search-button svg) {
            stroke: rgb(var(--text-light));
        }

        .nav-and-actions.is-active :global(.search-input:focus) {
            width: 85%;
            max-width: 320px;
            background-color: rgba(255, 255, 255, 0.2);
            border-color: rgb(var(--accent));
            box-shadow: 0 0 10px rgba(var(--accent-rgb), 0.5);
        }

        body.no-scroll {
            overflow: hidden;
        }
    }
</style>