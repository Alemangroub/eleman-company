---
import NavLink from './NavLink.astro';
import Search from './Search.astro';
const companyName = "شركة الايمان للاستثمار والتطوير العقاري";
const words = companyName.split(' ');
--- 
<header id="main-header" class="site-header">
    <div class="container">
        <div class="header-content">
            <div class="logo-container">
                <a href="/" class="company-logo">
                    {words.map((word, index) => (<span style={`animation-delay: ${index * 0.1}s`}>{word}&nbsp;</span>))}
                </a>
            </div>

            <div class="nav-and-actions">
                <nav class="main-nav">
                    <NavLink href="/" text="الرئيسية" />
                    <NavLink href="/about" text="من نحن" />
                    <NavLink href="/projects" text="مشاريعنا" />
                    <NavLink href="/contact" text="اتصل بنا" />
                </nav>
                <div class="header-actions">
                    <Search />
                    <a href="https://wa.me/+201002672901" class="whatsapp-icon" target="_blank" aria-label="تواصل معنا عبر واتساب">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.63A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    </a>
                </div>
            </div>

            <button class="hamburger-menu" aria-label="Toggle menu" aria-expanded="false">
                <svg class="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                <svg class="close-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
    </div>
</header>

<script>
    const hamburger = document.querySelector('.hamburger-menu');
    const navAndActions = document.querySelector('.nav-and-actions');
    const header = document.getElementById('main-header');

    hamburger.addEventListener('click', () => {
        const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!isExpanded));
        navAndActions.classList.toggle('is-active');
        header.classList.toggle('is-active');
        document.body.classList.toggle('no-scroll');
    });
</script>

<style>
    .site-header {
    background: rgba(var(--accent), 0.8);
    padding: 1rem 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    border-bottom: 1px solid rgba(var(--text-dark), 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    }

    .container {
        width: 90%;
        max-width: 1300px;
        margin: 0 auto;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .company-logo {
        color: rgb(var(--text-dark));
        text-decoration: none;
        font-size: 1.5rem;
        font-weight: 900;
        overflow: hidden;
    }

    .company-logo span {
        display: inline-block;
        opacity: 0;
        animation: fadeInDown 0.5s forwards;
    }

    .main-nav :global(a),
    .header-actions > *,
    .hamburger-menu {
        opacity: 0;
        animation: fadeInDown 0.5s forwards;
    }

    .main-nav :global(a):nth-child(1) { animation-delay: 0.6s; }
    .main-nav :global(a):nth-child(2) { animation-delay: 0.7s; }
    .main-nav :global(a):nth-child(3) { animation-delay: 0.8s; }
    .main-nav :global(a):nth-child(4) { animation-delay: 0.9s; }
    
    .header-actions > :first-child { animation-delay: 1s; }
    .header-actions > :last-child { animation-delay: 1.1s; }

    .hamburger-menu {
        animation-delay: 1.2s;
    }
    
    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .nav-and-actions {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .main-nav {
        display: flex;
        gap: 2.5rem;
    }

    .main-nav :global(a) {
        color: rgb(var(--text-dark));
        position: relative;
        transition: color 0.3s;
    }

    .main-nav :global(a)::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: -5px;
        left: 50%;
        transform: translateX(-50%);
        background-color: rgb(var(--text-dark));
        transition: width 0.3s;
    }

    .main-nav :global(a:hover)::after {
        width: 100%;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .whatsapp-icon svg {
        stroke: rgb(var(--text-dark));
        transition: transform 0.3s;
    }

    .whatsapp-icon:hover svg {
        transform: scale(1.1);
    }
    
    .hamburger-menu {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 1001;
        color: rgb(var(--text-dark));
    }

    .close-icon {
        display: none;
    }

    .hamburger-menu[aria-expanded="true"] .hamburger-icon {
        display: none;
    }
    .hamburger-menu[aria-expanded="true"] .close-icon {
        display: block;
    }

    @media (max-width: 1024px) {
        .main-nav {
            gap: 1.5rem;
        }
        .company-logo {
            font-size: 1.3rem;
        }
    }

    @media (max-width: 768px) {
        .hamburger-menu {
            display: block;
        }

        .nav-and-actions {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 2.5rem;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(var(--accent), 0.95);
            transform: translateX(100%);
            transition: transform 0.3s ease-in-out;
        }
        
        .nav-and-actions.is-active {
            display: flex;
            transform: translateX(0);
        }

        .main-nav {
            flex-direction: column;
            gap: 2rem;
            text-align: center;
        }
        
        .header-actions {
            flex-direction: column;
            gap: 2rem;
        }

        body.no-scroll {
            overflow: hidden;
        }
    }
</style>