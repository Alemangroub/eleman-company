---
import { projects } from '../data/projects.js';
---

<section id="under-construction" class="projects-section">
  <h2 class="section-title">مشاريع قيد الإنشاء</h2>
  <div class="projects-grid">
    {projects.underConstruction.map(project => (
      <div class="project-card">
        <div class="card-content">
          <img src={project.image} alt={project.name} class="project-image" />
          <div class="project-info">
            <h3>{project.name}</h3>
            <a href={`/project/${project.slug}`} class="details-button">عرض التفاصيل</a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* Styles are now identical to ProjectsSection.astro */
  .projects-section {
    padding: 5rem 2rem;
    text-align: center;
  }

  .section-title {
    font-size: 2.8rem;
    color: #fff;
    font-weight: 900;
    position: relative;
    padding-bottom: 1.5rem;
    margin-bottom: 4rem;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background-color: #ffd700; /* Gold accent to match the other section */
    border-radius: 2px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .project-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.3);
  }

  .card-content {
    height: 100%;
    background-color: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 15px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  .project-card:hover .card-content {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .project-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 1.5rem;
  }

  .project-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    margin-top: auto; /* Pushes info to the bottom */
  }

  .project-info h3 {
    font-size: 1.5rem;
    color: #fff;
    margin: 0;
  }

  .details-button {
    background-color: #ffd700;
    border: 1px solid #ffd700;
    color: #1a1a1a;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: bold;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .details-button:hover {
    background-color: transparent;
    color: #ffd700;
  }
</style>
