---
const today = new Date();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Quick Links Card -->
      <div class="footer-card">
        <h3 class="footer-title">روابط سريعة</h3>
        <ul class="footer-links">
          <li><a href="/">الرئيسية</a></li>
          <li><a href="/about">عن الشركة</a></li>
          <li><a href="/projects">مشاريعنا</a></li>
          <li><a href="/contact">تواصل معنا</a></li>
          <li><a href="#">سياسة الخصوصية</a></li>
          <li><a href="#">الشروط والأحكام</a></li>
        </ul>
      </div>

      <!-- About Card -->
      <div class="footer-card">
        <h3 class="footer-title">بنيان يرسخ الثقة</h3>
        <p>نصنع معالم الغد، ونصمم مشاريع عقارية استثنائية تلهم الحياة وتصنع الفرص.</p>
      </div>

      <!-- Contact Us Card -->
      <div class="footer-card">
        <h3 class="footer-title">تواصل معنا</h3>
        <ul class="contact-list">
            <li>
                <span class="icon location"></span>
                <span>مصر، سوهاج، طما، أعلى بنك القاهرة</span>
            </li>
            <li>
                <span class="icon whatsapp"></span>
                <a href="https://wa.me/201234567890" target="_blank">واتساب</a>
            </li>
            <li>
                <span class="icon email"></span>
                <a href="mailto:info@al-iman.dev">info@al-iman.dev</a>
            </li>
        </ul>
      </div>

      <!-- Newsletter Card -->
      <div class="footer-card">
        <h3 class="footer-title">اشترك في نشرتنا الإخبارية</h3>
        <p>كن على اطلاع دائم بآخر مشاريعنا وعروضنا الحصرية.</p>
        <form class="newsletter-form">
          <input type="email" placeholder="أدخل بريدك الإلكتروني" />
          <button type="submit">اشترك</button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {today.getFullYear()} <span class="company-name-gradient">شركة الايمان للتطوير العقاري</span>. جميع الحقوق محفوظة.</p>
    </div>
  </div>
</footer>

<style>
  :root {
    --footer-bg: var(--background, #f0f4f8);
    --card-bg: #ffffff;
    --card-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
    --title-color: var(--primary, #0b2d48);
    --text-color: var(--text-muted, #718096);
    --link-color: var(--text-dark, #2d3748);
    --link-hover-color: var(--accent, #d8648c);
    --underline-color: var(--accent, #d8648c);
    --button-text-color: #fff;
  }

  .site-footer {
    background-color: var(--footer-bg);
    padding: 5rem 0 2rem 0;
    text-align: right;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
    align-items: stretch;
  }

  .footer-card {
    background-color: var(--card-bg);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: var(--card-shadow);
    display: flex;
    flex-direction: column;
  }

  .footer-title {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
    font-weight: 700;
    background: linear-gradient(90deg, var(--accent), var(--secondary));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .footer-title::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: -10px;
    width: 50px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--secondary));
  }

  .footer-card p {
    color: var(--text-color);
    line-height: 1.8;
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 2;
    gap: 10px;
    flex-grow: 1;
  }

  .footer-links li a {
    color: var(--link-color);
    text-decoration: none;
    font-size: 1rem;
    margin-bottom: 0.8rem;
    display: inline-block;
    transition: color 0.3s ease;
  }

  .footer-links li a:hover {
    color: var(--link-hover-color);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-dark);
    font-size: 1rem;
  }

  .contact-list a {
    color: var(--text-dark);
    text-decoration: none;
    transition: color 0.3s ease;
    font-weight: 700;
  }

  .contact-list a:hover {
    color: var(--link-hover-color);
  }

  .contact-list .icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .contact-list .icon.location, .contact-list .icon.email {
    background-color: var(--accent, #d8648c);
  }

  .contact-list .icon.whatsapp {
    background-color: transparent;
    border: 2px solid var(--accent, #d8648c);
  }

  .newsletter-form {
    display: flex;
    margin-top: auto;
    border-radius: 50px;
    overflow: hidden;
    border: 1px solid #e0e0e0;
  }

  .newsletter-form input {
    flex-grow: 1;
    border: none;
    padding: 0.8rem 1.2rem;
    font-size: 1rem;
    background-color: transparent;
    font-family: 'Cairo', sans-serif;
  }

  .newsletter-form input:focus {
    outline: none;
  }

  .newsletter-form button {
    border: none;
    background: linear-gradient(90deg, var(--accent), var(--secondary));
    color: var(--button-text-color);
    padding: 0 1.5rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.3s ease;
    font-family: 'Cairo', sans-serif;
  }

  .newsletter-form button:hover {
    opacity: 0.85;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid #e0e0e0;
  }

  .footer-bottom p {
    margin: 0;
    color: var(--text-color);
    font-size: 0.9rem;
  }

  .company-name-gradient {
    background: linear-gradient(90deg, var(--accent), var(--secondary));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: bold;
  }

  @media (max-width: 1200px) {
    .footer-grid {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }
  }

  @media (max-width: 576px) {
    .footer-links {
      columns: 1;
    }
  }
</style>