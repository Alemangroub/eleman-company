<style>
  .site-footer {
    background-color: #f9f9f9;
    color: #000000;
    padding: 5rem 2rem;
    font-family: 'Cairo', sans-serif;
  }

  .footer-container {
    max-width: 1300px;
    margin: 0 auto;
  }

  .footer-main {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem; /* Gap between the cards */
  }

  .footer-column {
    background-color: #ffffff;
    border: 1px solid #eeeeee;
    border-radius: 20px;
    padding: 2.5rem;
    text-align: right;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .footer-column:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .footer-column h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: #000000;
    position: relative;
    padding-bottom: 1rem;
  }

  .footer-column h3::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 40px;
    height: 3px;
    background-color: var(--accent);
    border-radius: 2px;
  }

  .footer-column p, .footer-column li {
    font-size: 1rem;
    line-height: 1.9;
    margin-bottom: 1rem;
    color: #555555;
  }

  .footer-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-column a {
    color: #555555;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-column a:hover {
    color: var(--accent);
  }

  .newsletter-form {
    display: flex;
    border-radius: 50px;
    overflow: hidden;
    background-color: #ffffff;
    border: 1px solid #dddddd;
    max-width: 100%;
    margin-top: 1.5rem;
  }

  .newsletter-form input {
    flex-grow: 1;
    border: none;
    padding: 0.8rem 1.2rem;
    font-size: 1rem;
    outline: none;
    background: transparent;
    color: #000000;
  }

  .newsletter-form input::placeholder {
      color: #999999;
  }

  .newsletter-form button {
    background-color: var(--accent);
    color: #ffffff;
    border: none;
    padding: 0.8rem 1.5rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
    font-weight: bold;
    font-size: 1rem;
  }

  .newsletter-form button:hover {
    background-color: var(--accent-dark);
  }

  .contact-info li {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.2rem;
  }

  .contact-info .contact-link {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.2rem;
  }

  .contact-info svg {
    color: var(--accent);
    fill: var(--accent);
    flex-shrink: 0;
  }

  .footer-bottom {
    margin: 4rem auto 0 auto;
    padding-top: 2.5rem;
    border-top: 1px solid #eeeeee;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    color: #555555;
  }
  
  .social-icons {
    display: flex;
    gap: 2rem;
  }

  .social-icons a {
    color: #555555;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .social-icons a:hover {
    color: var(--accent);
    transform: scale(1.1);
  }

  @media (max-width: 992px) {
    .footer-main {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .site-footer {
        padding: 4rem 1.5rem;
    }
    .footer-main {
      text-align: center;
    }
     .footer-column h3::after {
        left: 50%;
        transform: translateX(50%);
     }
     .contact-info li {
        justify-content: center;
     }
     .contact-info .contact-link {
        justify-content: center;
     }
  }

  @media (max-width: 576px) {
    .footer-column {
      padding: 2rem 1.5rem;
    }
  }

</style>