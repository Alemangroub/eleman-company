---
const { href, text } = Astro.props;
---
<a href={href} class="nav-link">
  {text}
</a>

<style>
  .nav-link {
    font-family: 'Cairo', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #FFFFFF;
    text-decoration: none;
    position: relative;
    padding: 0.5rem 0;
  }

  @media (max-width: 768px) {
    .nav-link {
        font-size: 1.5rem;
    }
  }
</style>